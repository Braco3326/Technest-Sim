  "rules": [
    {
      "id": "R1", "slug": "connector-mate-mismatch", "module": "engine", "severity": "error",
      "title": "Connector mismatch",
      "check": "The two connectors must physically mate (connectorTypes.matesWith).",
      "teach": "An XLR male mates an XLR female; a TT plug mates a TT jack. If it doesn't fit, it isn't the right cable — never force it."
    },
    {
      "id": "R2", "slug": "signal-mismatch", "module": "engine", "severity": "error",
      "title": "Signal type mismatch",
      "check": "Source and destination signal types must be compatible: mic→mic-pre, line→line, digital→same digital format, pro (+4 dBu) vs consumer (-10 dBV) flagged.",
      "teach": "A mic into a line input is 40 dB too quiet; line into a mic-pre clips; AES3 into an analog input is just noise; consumer gear into pro gear runs 12 dB low."
    },
    {
      "id": "R3", "slug": "direction-mismatch", "module": "engine", "severity": "error",
      "title": "Direction mismatch",
      "check": "An output must feed an input (out→in). out→out and in→in are invalid; bidir ports accept either end.",
      "teach": "Signal flows one way: source → destination. Two outputs fighting each other can damage gear."
    },
    {
      "id": "R4", "slug": "phantom-power", "module": "logic/phantom", "severity": "error",
      "title": "Phantom power (+48 V)",
      "check": "A port flagged requiresPhantom must reach an input flagged providesPhantom with phantom enabled (error if missing). Warning if +48 V is enabled toward a ribbon/line source.",
      "teach": "Condensers (U 87) are silent without +48 V. Dynamics (SM58, RE20) ignore it. Vintage ribbons can be damaged by it."
    },
    {
      "id": "R5", "slug": "on-air-tally", "module": "logic/gpio", "severity": "warning",
      "title": "ON-AIR tally light",
      "check": "When a mic fader is open on a broadcast console, its GPIO tally output must drive an ON-AIR light (isOnAirTally chain complete).",
      "teach": "The red light is a safety contract: open mic = ON-AIR lit, or someone will walk in talking during the news."
    },
    {
      "id": "R6", "slug": "monitor-mute-open-mic", "module": "logic/gpio", "severity": "error",
      "title": "Monitor mute on open mic (feedback)",
      "check": "Opening a mic in the same room as active monitor outputs (isMonitorOut) must mute those monitors, else feedback loop detected.",
      "teach": "Studio speakers + open mic = larsen. Broadcast consoles mute the control-room monitors automatically when your mic is open."
    },
    {
      "id": "R7", "slug": "mix-minus-n1", "module": "logic/mixMinus", "severity": "error",
      "title": "Mix-minus / N-1 return echo",
      "check": "The feed sent to a remote codec must be the program MINUS the codec's own return (N-1). If the return is present in its own send, echo is detected.",
      "teach": "Send a guest their own voice back and they hear themselves delayed — unusable. Every duplex needs an N-1 bus."
    },
    {
      "id": "R8", "slug": "wordclock-sync", "module": "logic/clock", "severity": "error",
      "title": "Word clock master/slave & sample rate",
      "check": "Every digital audio connection needs exactly one clock master upstream; slaves lock to it. Two masters, no master, or mismatched sample rates on a link are errors.",
      "teach": "Digital audio without a shared clock = clicks and pops. One master (OCX HD or the interface), everyone else slaves."
    }
  ]
}
