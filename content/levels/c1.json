{
  "id": "c1",
  "version": 1,
  "domain": "duplex",
  "title": "C1 — Remote duplex: reporter on N-1",
  "brief": "A reporter in the field talks to the studio over an IP codec pair. Wire the field kit (RE50B → Scoopy+ S) and the studio side (Scoop5 S ↔ console), and feed the codec send from the N-1 bus — not the full program.",
  "objective": "Two-way conversation with no echo in the reporter's ears.",
  "devices": [
    {
      "instanceId": "re50-1",
      "deviceId": "ev-re50"
    },
    {
      "instanceId": "scoopy-1",
      "deviceId": "aeta-scoopy-plus-s"
    },
    {
      "instanceId": "scoop5-1",
      "deviceId": "aeta-scoop5-s"
    },
    {
      "instanceId": "iq-1",
      "deviceId": "axia-iq"
    }
  ],
  "requiredChain": [
    {
      "from": {
        "instance": "re50-1",
        "port": "out-xlr"
      },
      "to": {
        "instance": "scoopy-1",
        "port": "in-mic"
      }
    },
    {
      "from": {
        "instance": "scoopy-1",
        "port": "ip"
      },
      "to": {
        "instance": "scoop5-1",
        "port": "ip"
      }
    },
    {
      "from": {
        "instance": "scoop5-1",
        "port": "out-return"
      },
      "to": {
        "instance": "iq-1",
        "port": "in-line-1"
      }
    },
    {
      "from": {
        "instance": "iq-1",
        "port": "out-n1"
      },
      "to": {
        "instance": "scoop5-1",
        "port": "in-send"
      }
    }
  ],
  "logicChecks": [
    "R7"
  ],
  "successMessage": "Clean duplex — the reporter hears the studio, not herself. N-1 understood.",
  "examSeconds": 300,
  "environment": "radio",
  "layout": {
    "re50-1": [
      -2.8,
      0,
      1.6
    ],
    "scoopy-1": [
      -1.4,
      0,
      0.6
    ],
    "scoop5-1": [
      0.6,
      0,
      0.6
    ],
    "iq-1": [
      2.2,
      0,
      -1.2
    ]
  }
}
